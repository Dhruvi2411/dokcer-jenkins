pipeline {
    agent any

    environment {
        IMAGE_NAME = "ngo-website:latest"
        CONTAINER_NAME = "ngo-website-container"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
                echo "Workspace cleaned"
            }
        }

        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/Dhruvi2411/dokcer-jenkins.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t ${IMAGE_NAME} .
                '''
            }
        } 

        stage('Trivy Scan') {
            steps {
                sh '''
                trivy image \
                --format template \
                --template "@/usr/local/share/trivy/templates/html.tpl" \
                -o trivy-report.html \
                ${IMAGE_NAME} || true
                '''
            }
        }


        stage('Deploy Container') { 
            steps {
                withCredentials([
                    file(credentialsId: 'ENV_VAR', variable: 'env_file')
                ]) {
                    sh '''
                    docker rm -f ${CONTAINER_NAME} || true 

                    docker run -d -p 8000:8000 \
                    --env-file ${env_file} \
                    --name ${CONTAINER_NAME} \
                    ${IMAGE_NAME}
                    '''
                }
            }
        }

        stage('Publish Trivy Report') {
            steps {
                publishHTML([
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'trivy-report.html',
                    reportName: 'Trivy Security Report'
                ])
            }
        }

    }
}
